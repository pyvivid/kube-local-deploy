kubeadm token create --print-join-command
# The above command will give an output like below: 
kubeadm join 192.168.1.141:6443 --token p59j6j.1rssmbfhuad85u7z --discovery-token-ca-cert-hash sha256:7425a03fa2203eea7483a0e2d218469670dcb12689b6bb4f6a8d4aa409897833
# run the above command in each of the worker nodes, that you want to bring into the cluster.

# Then on the master node, check if the nodes are added into the cluster
kubectl get nodes

# With this the setup must be complete, you may proceed for test deployments

# You may have done all the kubernetes installations in the root user. To access the kubectl as root user run the following command
# in your terminal before you can actually run the kubectl commands. 
export KUBECONFIG=/etc/kubernetes/admin.conf

# If you are logged in as a specific user like uroot, then run the following commands to control the kubernetes cluster
mkdir -p ~/.kube
sudo cp /etc/kubernetes/admin.conf ~/.kube/config
sudo chown $(id -u):$(id -g) ~/.kube/config

