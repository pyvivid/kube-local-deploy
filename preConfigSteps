# This must update the k8s.conf file
# We are setting up the internal network for the K8S to communicate with each other
# Do this on all the instances within the K8s
cat <<EOF | sudo tee /etc/modules-l
oad.d/k8s.conf
overlay
br_netfilter
EOF


# Config of Kernel Parameters. Do this on all instances
cat <<EOF | sudo tee /etc/sysctl.d/kubernetes.conf
net.bridge.bridge-nf-call-iptables=1
net.bridge.bridge-nf-call-ip6tables=1
net.ipv4.ip_forward=1
EOF

# Verify the above config was set correctly. Do this on all instances
sudo sysctl --system

# verify that the ip forward was set correctly. Verify on all instances
sysctl net.ipv4.ip_forward

# Install Containerization Engine on all the instances. Exec on all 3 instances
sudo apt install -y containerd
sudo mkdir -p /etc/containerd
containerd config default | sudo tee /etc/containerd/config.toml
# Change the value of False to True
SystemCgroup = False | True

# Restart Containerd Daemons on each of the instances
sudo systemctl restart containerd
sudo systemctl enable containerd

# Test the status of the Containerd Application on each of the instances
systemctl status containerd

# Install the Ca-certs and transports for each of the instances
sudo apt install -y apt-transport-https ca-certificates curl gpg

# Add the Kubernetes repository on each of the instances
sudo mkdir -p /etc/apt/keyrings

curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.34/deb/Release.key \
| sudo gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg

echo 'deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.34/deb/ /' \
| sudo tee /etc/apt/sources.list.d/kubernetes.list

# Update the OS after the adding of the Ketyrings for Kubernetes
sudo apt update -y

# Install Kubelet, Kubeadm and Kubectl 
sudo apt install -y kubelet kubeadm kubectl

# disable the automatic updates of Kubelet, Kubeadm and Kubectl
sudo apt-mark hold kubelet kubeadm kubectl

# INitialize the Control Plane on the Master Node Only
sudo kubeadm init \
--pod-network-cidr=10.244.0.0/16

# Configure Kubectl to connect the the control plane
mkdir -p $HOME/.kube

sudo cp /etc/kubernetes/admin.conf $HOME/.kube/config

sudo chown $(id -u):$(id -g) $HOME/.kube/config

# At this stage the Kubectl get nodes will work, but will show as "NotReady". 
# Also we will see that the coredns pods are not running, because we dont have a Networking Component. 
# INstall Flannel for the overlay network
# You may skip Flannel and use CALICO or CILIUM also. CILIUM over Flannel/CALICO

kubectl apply -f https://github.com/flannel-io/flannel/releases/latest/download/kube-flannel.yml

# By now the nodes in the cluster must be "Ready"

# If your flannel network fails to start, use the following commands to re-initalize. ***Only if it fails. 
kubeadm init \
  --apiserver-advertise-address=192.168.1.141 \
  --pod-network-cidr=10.244.0.0/16

# ***Sometimes, based on the logged in user, we will need to set the context. 
# If ur root, run the below
export KUBECONFIG=/etc/kubernetes/admin.conf

# Install Cilium Now:
curl -L --remote-name https://github.com/cilium/cilium-cli/releases/latest/download/cilium-linux-amd64.tar.gz
tar xzvf cilium-linux-amd64.tar.gz
sudo mv cilium /usr/local/bin/

# After downloading Cilium, we need toinstall it. 
cilium install

